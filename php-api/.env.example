# Copy to .env and fill in. This PHP API is meant to run against a standalone PostgreSQL instance
# that the customer/organisation provisions and owns themselves — DB_HOST is NOT assumed to be a
# Docker service name ("db") or localhost; point it at wherever that Postgres instance actually is.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=enkl
DB_USER=enkl
DB_PASSWORD=change-me

# Must be a cryptographically random string, 32+ characters. If you also run the .NET API tier
# against the SAME database and want tokens interchangeable between the two, use the identical
# value here as that API's Jwt:SigningKey.
JWT_SIGNING_KEY=change-me-to-a-random-32-plus-character-string
JWT_ISSUER=Enkl.Api
JWT_AUDIENCE=Enkl.App
JWT_EXPIRY_HOURS=8

# Runs any not-yet-applied migrations (see src/Db/migrations) once at process start. Safe to leave
# on permanently — already-applied migrations are tracked in the migrations_history table and
# skipped. Turn off if your organisation prefers to run `php migrate.php` manually/out-of-band
# instead of letting the API mutate schema on its own boot.
RUN_MIGRATIONS_ON_STARTUP=true

# development | production — production hides internal exception details from API responses.
APP_ENV=production

# The browser-facing origin (scheme + host, no trailing slash) this API is reached at. SAML needs a
# fixed, correct SP entity id / ACS URL to register with an identity provider — this can't be
# derived from the incoming request if there's a reverse proxy in front that doesn't forward the
# original scheme (see api/Enkl.Api/appsettings.json's App:PublicBaseUrl for the .NET side's
# identical need). Also used to build the redirect URLs SamlController sends the browser back to
# after a login (?ssoCode=.../?ssoError=...).
APP_PUBLIC_BASE_URL=http://localhost
