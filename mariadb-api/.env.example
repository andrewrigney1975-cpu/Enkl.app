# Copy to .env and fill in. This API is meant to run against a standalone MariaDB instance that the
# customer/organisation provisions and owns themselves — DB_HOST is NOT assumed to be a Docker
# service name or localhost; point it at wherever that MariaDB instance actually is.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=enkl
DB_USER=enkl
DB_PASSWORD=change-me

# Credentials for the dedicated, SELECT-only user PublicQueryExecutionService uses to run a saved
# query's SQL text (see src/Db/migrations/006_saved_queries_and_public_api.sql) — never the DB_USER
# above. Must match whatever password that migration actually created the user with.
DB_PUBLIC_QUERY_USER=enkl_public_query
DB_PUBLIC_QUERY_PASSWORD=enkl_public_query_dev_password

# Must be a cryptographically random string, 32+ characters. If you also run the .NET or php-api
# tiers and want tokens interchangeable between them, use the identical value here as those tiers'
# own signing key.
JWT_SIGNING_KEY=change-me-to-a-random-32-plus-character-string
JWT_ISSUER=Enkl.Api
JWT_AUDIENCE=Enkl.App
JWT_EXPIRY_HOURS=8

# Runs any not-yet-applied migrations (see src/Db/migrations) once at process start. Safe to leave
# on permanently — already-applied migrations are tracked in the migrations_history table and
# skipped. Turn off if your organisation prefers to run `php migrate.php` manually/out-of-band
# instead of letting the API mutate schema on its own boot. Note: MariaDB DDL isn't transactional —
# see src/Db/Migrator.php's own doc comment for what that means if a migration fails partway.
RUN_MIGRATIONS_ON_STARTUP=true

# development | production — production hides internal exception details from API responses.
APP_ENV=production

# The browser-facing origin (scheme + host, no trailing slash) this API is reached at. SAML needs a
# fixed, correct SP entity id / ACS URL to register with an identity provider — this can't be
# derived from the incoming request if there's a reverse proxy in front that doesn't forward the
# original scheme. Also used to build the redirect URLs SamlController sends the browser back to
# after a login (?ssoCode=.../?ssoError=...).
APP_PUBLIC_BASE_URL=http://localhost
